{
  "name": "@ccl/mcp",
  "version": "0.0.0",
  "description": "CCL MCP server — /ccl command handler and npx ccl setup.",
  "license": "MIT",
  "author": {
    "name": "CCL maintainers",
    "email": "security@ccl.dev"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ccl": "./dist/setup.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./commands/ccl": {
      "types": "./dist/commands/ccl.d.ts",
      "default": "./dist/commands/ccl.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx test/**/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@ccl/core": "*",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
